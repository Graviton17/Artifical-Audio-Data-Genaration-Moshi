      "real_end_sec": null,
      "error_time": null
    },
    {
      "turn_id": "t4",
      "speaker": "speaker_2",
      "text": "अच्छा तो... सबसे पहले सोफा और डाइनिंग टेबल देख रहा हूँ।",
