      "real_end_sec": null,
      "error_time": null
    },
    {
      "turn_id": "t2",
      "speaker": "speaker_2",
      "text": "धन्यवाद, बहुत खुशी हो रही है, पर काम बहुत ज़्यादा है दादा।",
